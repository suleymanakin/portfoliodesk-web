// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums — DB seviyesinde veri kalitesi
// ---------------------------------------------------------------------------
enum UserRole {
  admin
  investor
}

enum MovementType {
  deposit
  withdraw
}

// ---------------------------------------------------------------------------
// User — Giriş yapan kullanıcı (admin veya yatırımcı)
// ---------------------------------------------------------------------------
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(100)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole
  investorId   Int?     @unique @map("investor_id") // Yatırımcı kullanıcılar için
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  investor Investor? @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@map("users")
}

// ---------------------------------------------------------------------------
// Investor — Yatırımcı profil ve güncel sermaye
// ---------------------------------------------------------------------------
model Investor {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(200)
  initialCapital  Decimal   @db.Decimal(20, 10)
  currentCapital  Decimal   @db.Decimal(20, 10)
  realizedProfit  Decimal   @default(0) @db.Decimal(20, 10) // Kesinleşen dönem kârlarının anaparaya eklenmiş kısmı
  profitResetDate DateTime? @db.Date // Son kesinleşen dönem sonu (dönem kârı bu tarihten sonra hesaplanır)
  commissionRate  Decimal   @default(0) @db.Decimal(10, 4)
  billingDay      Int? // 1-28, null = ay sonu
  startDate       DateTime? @db.Date // Yatırımcının sisteme giriş tarihi
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // --- Yatırımcı paneli KPI gösterimi (kalıcı). Hesaplamada KULLANILMAZ. ---
  // settlementEngine, calculationEngine, summaryService ve diğer iş mantığı
  // bu alanları okumamalı; yalnızca frontend / rapor gösterimi içindir.
  dashboardDisplayAnapara   Decimal?  @map("dashboard_display_anapara") @db.Decimal(20, 10)
  dashboardDisplayEntryDate DateTime? @map("dashboard_display_entry_date") @db.Date

  user        User?
  history     InvestorHistory[]
  settlements MonthlySettlement[]
  movements   CapitalMovement[]

  @@map("investors")
}

// ---------------------------------------------------------------------------
// CapitalMovement — Yatırımcı para giriş/çıkış (Ana Para hareketleri)
// ---------------------------------------------------------------------------
model CapitalMovement {
  id         Int          @id @default(autoincrement())
  investorId Int
  date       DateTime     @db.Date
  type       MovementType
  amount     Decimal      @db.Decimal(20, 10)
  note       String?      @db.VarChar(500)
  createdAt  DateTime     @default(now())

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([investorId, date, id])
  @@map("capital_movements")
}

// ---------------------------------------------------------------------------
// DailyResult — Portföy geneli günlük sonuç
// ---------------------------------------------------------------------------
model DailyResult {
  id                  Int      @id @default(autoincrement())
  date                DateTime @unique @db.Date
  dailyPercentage     Decimal  @db.Decimal(10, 6)
  totalPortfolioValue Decimal  @db.Decimal(20, 10)
  totalCommission     Decimal  @default(0) @db.Decimal(20, 10)
  createdAt           DateTime @default(now())

  investorHistories InvestorHistory[]

  @@map("daily_results")
}

// ---------------------------------------------------------------------------
// InvestorHistory — Yatırımcı bazlı günlük audit trail
// ---------------------------------------------------------------------------
model InvestorHistory {
  id               Int      @id @default(autoincrement())
  investorId       Int
  dailyResultId    Int?
  date             DateTime @db.Date
  capitalBefore    Decimal  @db.Decimal(20, 10)
  capitalAfter     Decimal  @db.Decimal(20, 10)
  dailyProfit      Decimal  @db.Decimal(20, 10)
  commissionAmount Decimal  @default(0) @db.Decimal(20, 10)

  investor    Investor     @relation(fields: [investorId], references: [id], onDelete: Cascade)
  dailyResult DailyResult? @relation(fields: [dailyResultId], references: [id], onDelete: Cascade)

  @@unique([investorId, date])
  @@map("investor_history")
}

// ---------------------------------------------------------------------------
// MonthlySettlement — Aylık komisyon hesap kesimi
// ---------------------------------------------------------------------------
model MonthlySettlement {
  id               Int      @id @default(autoincrement())
  investorId       Int
  year             Int
  month            Int
  periodStart      DateTime @db.Date
  periodEnd        DateTime @db.Date
  capitalStart     Decimal  @db.Decimal(20, 10)
  capitalEnd       Decimal  @db.Decimal(20, 10)
  monthlyProfit    Decimal  @db.Decimal(20, 10)
  commissionAmount Decimal  @default(0) @db.Decimal(20, 10)
  isSettled        Boolean  @default(false)
  carryForwardLoss Decimal  @default(0) @db.Decimal(20, 10)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, year, month])
  @@index([investorId])
  @@map("monthly_settlements")
}
